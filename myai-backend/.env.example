# Server
APP_NAME="AI Recruitment Assistant"
ENVIRONMENT="development"
LOG_LEVEL="INFO"

# CORS (comma-separated)
# Add your frontend domain in production, for example:
# ALLOWED_ORIGINS="https://recruit.example.com"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Database (optional for local MVP mode)
# Leave empty to run local-first with in-memory candidate/resume storage
# and built-in fallback resume templates.
DATABASE_URL=""

# JWT
JWT_SECRET="change-me"
JWT_ACCESS_TOKEN_MINUTES="30"
JWT_REFRESH_TOKEN_DAYS="30"

# LLM Providers
DEFAULT_LLM_PROVIDER="gemini"
DEFAULT_GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_KEY=""
OPENWEBUI_BASE_URL="http://localhost:8080"
OPENWEBUI_API_KEY=""

